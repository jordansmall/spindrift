# Copy to harness.env (gitignored) and fill in — or export these in your shell.
# Secrets only: every other knob is set via the Consumer flake's `settings`
# or an explicit CLI flag (see docs/reference.md and docs/flake-options.md).

# Anthropic API key; set this or CLAUDE_CODE_OAUTH_TOKEN
ANTHROPIC_API_KEY=

# Claude Code OAuth token (run 'claude setup-token'); set this or ANTHROPIC_API_KEY
CLAUDE_CODE_OAUTH_TOKEN=

# fine-grained PAT scoped to the target repo — Contents/PR/Issues/Metadata RW
GH_TOKEN=

# Jira API token (Cloud: paired with JIRA_EMAIL for Basic auth; Server/Data Center: used alone as a Bearer PAT); required when ISSUE_TRACKER=jira
JIRA_TOKEN=

