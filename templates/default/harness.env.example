# Copy to harness.env (gitignored) and fill in — or export these in your shell.

# Target GitHub repository the agents work on.
REPO_SLUG=owner/repo

# GitHub token used by the `gh` CLI inside each container (and by `bin/run` to
# list issues on the host). Use a fine-grained token scoped to ONLY the target
# repo — that bounds the blast radius of `--dangerously-skip-permissions`.
# Repo permissions:
#   Contents:      Read and write   (clone + push branches)
#   Pull requests: Read and write   (open PRs, incl. drafts)
#   Issues:        Read and write   (read the issue; write only for the
#                                    "if blocked" path that comments on it —
#                                    drop that and Read is enough)
#   Metadata:      Read             (mandatory baseline, auto-selected)
#   Workflows:     Read and write   (ONLY if an issue edits .github/workflows/*)
GH_TOKEN=

# Claude Code auth — get one with `claude setup-token` on the host.
CLAUDE_CODE_OAUTH_TOKEN=
# ...or use an API key instead (set one or the other):
# ANTHROPIC_API_KEY=

# Optional overrides (defaults shown):
# LABEL=ready-for-agent
# BASE_BRANCH=main
# MAX_PARALLEL=3
# BRANCH_PREFIX=agent/issue-
# IMAGE=spindrift:latest

# Commit identity for the agent's branch. Required: unset = inherit the host's
# `git config user.name`/`user.email`. If neither is set here nor on the host,
# `bin/run` exits rather than committing under an arbitrary identity.
# GIT_USER_NAME=
# GIT_USER_EMAIL=
