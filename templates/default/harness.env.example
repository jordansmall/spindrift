# Copy to harness.env (gitignored) and fill in — or export these in your shell.

# Anthropic API key; set this or CLAUDE_CODE_OAUTH_TOKEN
ANTHROPIC_API_KEY=

# open issues carrying this label fence all higher-numbered issues; empty disables fencing
# BARRIER_LABEL=

# default branch agent PRs merge into
# BASE_BRANCH=main

# prefix for agent-cut branches
# BRANCH_PREFIX=agent/issue-

# when non-empty, adds --unshare-net to bwrap; requires slirp/pasta for DNS; by default bwrap shares the host network namespace (host-loopback reachable)
# BWRAP_UNSHARE_NET=

# Claude Code OAuth token (run 'claude setup-token'); set this or ANTHROPIC_API_KEY
CLAUDE_CODE_OAUTH_TOKEN=

# label the launcher swaps on after a successful merge
# COMPLETE_LABEL=agent-complete

# seconds between dependency-wave poll iterations
# DEPS_POLL_SECS=30

# total seconds to wait for dependency-wave completion before aborting
# DEPS_WAIT_SECS=7200

# seconds before the devShell probe is abandoned and the baked toolchain is used
# DEV_SHELL_PROBE_TIMEOUT=300

# label swapped on when the agent box exits non-zero
# FAILED_LABEL=agent-failed

# fine-grained PAT scoped to the target repo — Contents/PR/Issues/Metadata RW
GH_TOKEN=

# commit identity email; falls back to host git config user.email
# GIT_USER_EMAIL=

# commit identity name; falls back to host git config user.name
# GIT_USER_NAME=

# jitter seconds added to 429 hold duration to spread re-dispatch
# HOLD_JITTER_SECS=5

# label swapped on from LABEL when an issue enters the queue
# IN_PROGRESS_LABEL=agent-in-progress

# dispatch only this issue number, bypassing the LABEL query; empty discovers by LABEL
# ISSUE_NUMBER=

# issues carrying this label are dispatchable (the launch button)
# LABEL=ready-for-agent

# fix-agent passes when CI is genuinely red before marking agent-failed; 0 disables self-healing
# MAX_FIX_ATTEMPTS=3

# dependency-wave concurrency cap; 0 means unlimited
# MAX_JOBS=0

# maximum concurrent agent containers
# MAX_PARALLEL=3

# max memory per agent container (--memory); empty string disables the limit
# MEMORY_LIMIT=4g

# seconds between merge-gate poll iterations
# MERGE_POLL_INTERVAL=30

# total seconds to wait for CI green before abandoning the merge attempt
# MERGE_POLL_TIMEOUT=1800

# primary (implementor) Claude model for the agent (zero-rebuild runtime switch)
# MODEL=claude-sonnet-4-6

# --network value for podman run; empty applies no flag (podman NAT default); set to 'pasta' to restrict egress
# PODMAN_NETWORK=

# max processes per agent container (--pids-limit); empty string disables the limit
# PIDS_LIMIT=512

# target GitHub repository the agents work on
REPO_SLUG=owner/repo

# reviewer subagent model tier; empty omits the scout/reviewer --agents from the claude invocation
# REVIEW_MODEL=claude-opus-4-8

# scout subagent model tier; empty omits the scout/reviewer --agents from the claude invocation
# SCOUT_MODEL=claude-haiku-4-5-20251001

# host directory mounted over /agent/prompts for zero-rebuild prompt iteration
# SPINDRIFT_PROMPT_DIR=

# base backoff seconds per retry for 529/overloaded and network transients
# TRANSIENT_BACKOFF_SECS=30

# max retries for transient exits (529/network backoff; consecutive 429 holds)
# TRANSIENT_RETRY_MAX=3

