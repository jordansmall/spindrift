# Copy to harness.env (gitignored) and fill in — or export these in your shell.
# Secrets only: every other knob is set via the Consumer flake's `settings`
# or an explicit CLI flag (see docs/reference.md and docs/flake-options.md).
#
# Sourcing every secret below from an external vault via its <NAME>_CMD form
# (rbw, op, pass, vault, ...) is the preferred, highly encouraged way to
# supply secrets — see each entry's comment below and docs/reference.md's
# Runtime configuration section. harness.env then holds fetch recipes, not
# live credentials.

# Anthropic API key; set this or CLAUDE_CODE_OAUTH_TOKEN
# Preferred: fetch this from a vault instead of the plaintext value below —
# ANTHROPIC_API_KEY_CMD="rbw get spindrift-anthropic-api-key" (or an op/pass/vault
# read); the command's stdout wins over ANTHROPIC_API_KEY and is never baked,
# logged, or written to disk.
ANTHROPIC_API_KEY=

# opt-in two-actor separation (ADR 0016): a second machine user's fine-grained PAT for the Box only — the launcher keeps using its own GH_TOKEN for merges, labels, and all host-side forge calls, while the Box receives this value as its GH_TOKEN instead; empty (default) leaves the single-token flow unchanged. Pair with a repository ruleset that bars this user from updating the base branch and bypass-lists only the launcher's user — see docs/reference.md's two-actor separation recipe
# Preferred: fetch this from a vault instead of the plaintext value below —
# BOX_GH_TOKEN_CMD="rbw get spindrift-box-gh-token" (or an op/pass/vault
# read); the command's stdout wins over BOX_GH_TOKEN and is never baked,
# logged, or written to disk.
BOX_GH_TOKEN=

# Claude Code OAuth token (run 'claude setup-token'); set this or ANTHROPIC_API_KEY
# Preferred: fetch this from a vault instead of the plaintext value below —
# CLAUDE_CODE_OAUTH_TOKEN_CMD="rbw get spindrift-claude-code-oauth-token" (or an op/pass/vault
# read); the command's stdout wins over CLAUDE_CODE_OAUTH_TOKEN and is never baked,
# logged, or written to disk.
CLAUDE_CODE_OAUTH_TOKEN=

# fine-grained PAT scoped to the target repo — Contents/PR/Issues/Metadata RW; required unless CODE_FORGE and ISSUE_TRACKER are both local
# Preferred: fetch this from a vault instead of the plaintext value below —
# GH_TOKEN_CMD="rbw get spindrift-gh-token" (or an op/pass/vault
# read); the command's stdout wins over GH_TOKEN and is never baked,
# logged, or written to disk.
GH_TOKEN=

# Jira API token (Cloud: paired with JIRA_EMAIL for Basic auth; Server/Data Center: used alone as a Bearer PAT); required when ISSUE_TRACKER=jira
# Preferred: fetch this from a vault instead of the plaintext value below —
# JIRA_TOKEN_CMD="rbw get spindrift-jira-token" (or an op/pass/vault
# read); the command's stdout wins over JIRA_TOKEN and is never baked,
# logged, or written to disk.
JIRA_TOKEN=

