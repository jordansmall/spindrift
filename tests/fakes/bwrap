#!/usr/bin/env bash
# Fake bwrap for tests. Records every invocation to $BWRAP_LOG and simulates
# just enough behaviour for the harness scripts: parses --setenv KEY VAL pairs
# (bwrap's env-var injection), emits scripted SPINDRIFT_OUTCOME lines per
# issue, and exits with FAKE_BWRAP_RUN_EXIT. Never spawns a real sandbox.
#
# Secrets (GH_TOKEN, CLAUDE_CODE_OAUTH_TOKEN, ANTHROPIC_API_KEY) are no longer
# passed via --setenv; they arrive via the inherited process environment. The
# fake logs them as ENV_SECRET:<name> so tests can verify delivery without
# exposing values in the recorded argv.
set -euo pipefail

: "${BWRAP_LOG:?BWRAP_LOG must point at a log file}"
printf '%s\n' "$*" >>"$BWRAP_LOG"

# Log secret env vars received via process environment (name only, not value).
for _secret in GH_TOKEN CLAUDE_CODE_OAUTH_TOKEN ANTHROPIC_API_KEY; do
  if [ -n "${!_secret:-}" ]; then
    printf 'ENV_SECRET:%s\n' "$_secret" >>"$BWRAP_LOG"
  fi
done

issue_num=""
args=("$@")
i=0
while [ "$i" -lt "${#args[@]}" ]; do
  if [ "${args[$i]}" = "--setenv" ]; then
    key="${args[$((i + 1))]}"
    val="${args[$((i + 2))]}"
    case "$key" in
      ISSUE_NUMBER) issue_num="$val" ;;
    esac
    i=$((i + 3))
  else
    i=$((i + 1))
  fi
done

if [ -n "$issue_num" ]; then
  outcome_var="FAKE_BWRAP_OUTCOME_${issue_num}"
  outcome_val="${!outcome_var:-}"
  [ -n "$outcome_val" ] && printf '%s\n' "$outcome_val"
fi

exit "${FAKE_BWRAP_RUN_EXIT:-0}"
