#!/usr/bin/env bash
# Fake docker for tests. Mirrors the fake podman: records every invocation's
# arguments to $DOCKER_LOG (one line per call) and simulates just enough
# behaviour for the harness scripts (`image exists`, `load`, `run`). Never
# touches a real container. Exists so the `runtime = "docker"` knob can be
# exercised without podman.
set -euo pipefail

: "${DOCKER_LOG:?DOCKER_LOG must point at a log file}"
printf '%s\n' "$*" >>"$DOCKER_LOG"

case "${1:-}" in
  image)
    # `docker image inspect <ref>` — presence is controlled by the test.
    # Also accept the legacy `image exists` verb for any tests not yet updated.
    if [ "${2:-}" = "inspect" ] || [ "${2:-}" = "exists" ]; then
      [ "${FAKE_DOCKER_IMAGE_PRESENT:-0}" = "1" ]
      exit $?
    fi
    ;;
  run)
    # `docker run ...` — scripted exit code, so tests can drive the Go launcher's
    # failure path (the on-failure label swap).
    exit "${FAKE_DOCKER_RUN_EXIT:-0}"
    ;;
esac

exit 0
