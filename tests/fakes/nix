#!/usr/bin/env bash
# Fake nix for the `build` tests. Records every invocation to $NIX_LOG and
# simulates whether this host can realize a Linux derivation: `nix build`
# succeeds only when FAKE_NIX_BUILD_OK=1 (a host with a Linux builder),
# otherwise it fails the way a builder-less darwin host does — driving the
# ephemeral-container fallback. Never touches the real nix store.
set -euo pipefail

: "${NIX_LOG:?NIX_LOG must point at a log file}"
printf '%s\n' "$*" >>"$NIX_LOG"

case "${1:-}" in
  build)
    if [ "${FAKE_NIX_BUILD_OK:-0}" = "1" ]; then
      exit 0
    fi
    # FAKE_NIX_BUILD_STDERR overrides the default builder-missing message so
    # tests can inject genuine derivation errors (non-builder failures).
    if [ -n "${FAKE_NIX_BUILD_STDERR:-}" ]; then
      printf '%s\n' "$FAKE_NIX_BUILD_STDERR" >&2
    else
      echo "error: a 'aarch64-linux' with features {} is required to build, but I am a 'aarch64-darwin'" >&2
    fi
    exit 1
    ;;
  develop)
    if [ "${FAKE_NIX_DEV_SHELL_HANG:-0}" = "1" ]; then
      sleep 9999
    fi
    if [ "${FAKE_NIX_DEV_SHELL_OK:-0}" = "1" ]; then
      exit 0
    fi
    echo "error: flake 'path:.' does not provide attribute 'devShells.x86_64-linux.default'" >&2
    exit 1
    ;;
esac

exit 0
