#!/usr/bin/env bash
# Stub-agent fake `claude` for tests. NEVER calls a real LLM.
#
# It records the rendered prompt (the value passed after -p) to
# $CLAUDE_PROMPT_FILE and a marker to $CLAUDE_LOG. When FAKE_CLAUDE_COMMIT=1 it
# also plays the scripted agent: make a change, commit it, push the current
# branch, and open a (faked) PR — exercising the full clone -> branch -> agent
# -> commit -> push -> PR pipeline against a local bare repo.
set -euo pipefail

: "${CLAUDE_LOG:?CLAUDE_LOG must point at a log file}"
# Snapshot the call index (0 for this process's first invocation) before this
# invocation appends its own "claude invoked for issue" line below, so
# FAKE_CLAUDE_NO_OUTCOME_FIRST_CALL_ONLY can tell first call from resume.
call_index="$(grep -c '^claude invoked for issue' "$CLAUDE_LOG" 2>/dev/null || true)"
printf '%s\n' "$*" >>"$CLAUDE_LOG"

prompt=""
agents=""
model=""
while [ $# -gt 0 ]; do
  case "$1" in
    -p)
      prompt="${2:-}"
      shift 2
      ;;
    --agents)
      agents="${2:-}"
      shift 2
      ;;
    --model)
      model="${2:-}"
      shift 2
      ;;
    *) shift ;;
  esac
done

printf '%s' "$prompt" >"${CLAUDE_PROMPT_FILE:-/dev/null}"
printf '%s' "$agents" >"${CLAUDE_AGENTS_FILE:-/dev/null}"
printf 'claude invoked for issue #%s model=%s\n' "${ISSUE_NUMBER:-?}" "$model" >>"$CLAUDE_LOG"

# Report any skills discoverable at the path Claude Code scans. Real claude -p
# discovers a skill only as a directory holding a SKILL.md
# ($HOME/.claude/skills/<name>/SKILL.md), never a flat <name>.md file; this
# fake mirrors that so tests assert real discovery without a live LLM.
if [ -d "${HOME:-}/.claude/skills" ]; then
  for _skill in "${HOME}/.claude/skills/"*/SKILL.md; do
    [ -f "$_skill" ] && printf 'skill discovered: %s\n' "$(basename "$(dirname "$_skill")")" >>"$CLAUDE_LOG"
  done
fi

# Conflict-resolution mode: simulate an agent that resolves rebase conflicts,
# then continues the rebase. The entrypoint checks for completion afterwards.
# Only run the git ops -- and only this fake's early exit -- when a rebase is
# actually in progress. FAKE_CLAUDE_RESOLVE_CONFLICT is exported for the whole
# entrypoint run, so it is still "1" on every later invocation of this same
# fake too (the main run, and now the resume-once recovery pass, issue
# #1607); gating the exit on an in-progress rebase, not just the flag, lets
# those later calls fall through to the ordinary stream-json path below
# instead of silently short-circuiting with no output.
#
# Ordinary conflicted files accept the being-rebased version (theirs). A file
# that declares itself generated ("DO NOT EDIT" / "Code generated by X from
# Y") is instead resolved per the conflict-resolve prompt (issue #403):
# merge both sides in its source file, then regenerate the artifact by
# running the command named in its own header — never hand-merge the
# artifact's conflict markers directly.
if [ "${FAKE_CLAUDE_RESOLVE_CONFLICT:-0}" = "1" ] && { [ -d ".git/rebase-merge" ] || [ -d ".git/rebase-apply" ]; }; then
  # First pass: resolve generated files by merging their source and
  # regenerating, staging both the source and the regenerated artifact.
  while IFS= read -r _f; do
    if grep -qi 'do not edit' "$_f" 2>/dev/null; then
      _header="$(grep -i 'code generated by' "$_f" | head -1)"
      _cmd="$(printf '%s' "$_header" | sed -E 's/.*[Cc]ode generated by ([^ ]+) from.*/\1/')"
      _src="$(printf '%s' "$_header" | sed -E 's/.*from ([^ ]+) DO NOT EDIT.*/\1/;s/\.$//')"
      grep -vE '^(<<<<<<<|=======|>>>>>>>)' "$_src" >"$_src.merged"
      mv "$_src.merged" "$_src"
      git add "$_src"
      bash "$_cmd"
      git add "$_f"
    fi
  done < <(git diff --name-only --diff-filter=U)
  # Second pass: whatever is still unmerged is an ordinary file (the first
  # pass already staged generated files and their sources) — accept the
  # incoming side.
  while IFS= read -r _f; do
    git checkout --theirs "$_f"
    git add "$_f"
  done < <(git diff --name-only --diff-filter=U)
  GIT_EDITOR=true git rebase --continue
  exit 0
fi

if [ "${FAKE_CLAUDE_COMMIT:-0}" = "1" ]; then
  branch="$(git rev-parse --abbrev-ref HEAD)"
  printf 'stub agent change for issue #%s\n' "${ISSUE_NUMBER:-0}" >agent-change.txt
  git add -A
fi
# A resume call (issue #1607's recovery pass) re-invokes this fake against a
# tree the first call already committed and pushed -- staging the identical
# fixture content leaves nothing to commit, so skip straight past the rest of
# this block instead of a `git commit` erroring on an empty index.
if [ "${FAKE_CLAUDE_COMMIT:-0}" = "1" ] && ! git diff --cached --quiet; then
  git commit -m "feat: stub agent commit for #${ISSUE_NUMBER:-0}" >/dev/null
  git push origin "$branch" >/dev/null 2>&1
  gh pr create \
    --base "${BASE_BRANCH:-main}" \
    --head "$branch" \
    --title "feat: resolve issue #${ISSUE_NUMBER:-0}" \
    --body "Closes #${ISSUE_NUMBER:-0}"
fi

# Emit a stream-json transcript to stdout, matching `--output-format stream-json`:
# NDJSON events ending in a `result` event whose `.result` holds the agent's final
# message — here a status=ready outcome line the entrypoint must surface.
#
# FAKE_CLAUDE_NO_OUTCOME=1 simulates a driver that forgot to emit one (issue
# #593's entrypoint backstop): the result event's text carries no
# SPINDRIFT_OUTCOME line at all.
#
# FAKE_CLAUDE_NO_OUTCOME_FIRST_CALL_ONLY=1 simulates the same forgetful driver
# only on this fake's first invocation within a test, then emits a real
# outcome on every call after — for exercising the resume-once recovery pass
# (issue #1607), which must see the second (resumed) call succeed.
printf '{"type":"system","subtype":"init","session_id":"fake"}\n'
printf '{"type":"assistant","message":{"content":[{"type":"text","text":"implementing #%s"}]}}\n' "${ISSUE_NUMBER:-0}"
if [ "${FAKE_CLAUDE_NO_OUTCOME:-0}" = "1" ] || { [ "${FAKE_CLAUDE_NO_OUTCOME_FIRST_CALL_ONLY:-0}" = "1" ] && [ "${call_index:-0}" = "0" ]; }; then
  printf '{"type":"result","subtype":"success","is_error":false,"result":"done, but forgot to report back"}\n'
else
  printf '{"type":"result","subtype":"success","is_error":false,"result":"SPINDRIFT_OUTCOME issue=%s landing=https://github.com/%s/pull/1 status=ready note=fake"}\n' \
    "${ISSUE_NUMBER:-0}" "${REPO_SLUG:-owner/repo}"
fi

# FAKE_CLAUDE_CRASH_EXIT simulates a driver killed by a transient
# infrastructure failure (rate limit, overload, network blip) with no outcome
# line: the launcher's own ClassifyTransient/retry path -- not the
# entrypoint's outcome backstop -- owns this case (issue #593), so the
# entrypoint must propagate this exit code untouched.
if [ -n "${FAKE_CLAUDE_CRASH_EXIT:-}" ]; then
  exit "$FAKE_CLAUDE_CRASH_EXIT"
fi

exit 0
