#!/usr/bin/env bash
# Fake gh for tests. Records every invocation to $GH_LOG and models just enough
# of the issue label lifecycle (issue #15) to prove `run` idempotency:
#
#   * `issue list --label L` prints the FAKE_GH_ISSUES rows whose *current*
#     lifecycle label is L. An issue that has never been edited is treated as
#     carrying whatever label is queried (its initial "ready" state), so a first
#     run sees every seeded issue regardless of the query label. Once an issue
#     has been edited it matches only its recorded label.
#   * `issue edit N --add-label A --remove-label R` records N's new label A in
#     $GH_STATE, so a subsequent `issue list --label R` no longer matches it.
#   * `pr create` / `auth setup-git` are recorded, no-op.
set -euo pipefail

: "${GH_LOG:?GH_LOG must point at a log file}"
printf '%s\n' "$*" >>"$GH_LOG"

# Per-test label state (issue number -> current lifecycle label), kept beside the
# log so it is isolated per test yet persists across two `run` invocations.
GH_STATE="${GH_STATE:-$GH_LOG.state}"

case "${1:-}" in
  issue)
    case "${2:-}" in
      list)
        want=""
        args=("$@")
        for ((i = 0; i < ${#args[@]}; i++)); do
          [ "${args[i]}" = "--label" ] && want="${args[i + 1]:-}"
        done
        while IFS=$'\t' read -r num title; do
          [ -n "$num" ] || continue
          cur=""
          if [ -f "$GH_STATE" ]; then
            while IFS=$'\t' read -r k v; do
              [ "$k" = "$num" ] && cur="$v"
            done < "$GH_STATE"
          fi
          if [ -z "$cur" ] || [ "$cur" = "$want" ]; then
            printf '%s\t%s\n' "$num" "$title"
          fi
        done <<EOF
${FAKE_GH_ISSUES:-}
EOF
        ;;
      edit)
        num="${3:-}"
        add=""
        args=("$@")
        for ((i = 0; i < ${#args[@]}; i++)); do
          [ "${args[i]}" = "--add-label" ] && add="${args[i + 1]:-}"
        done
        [ -n "$num" ] && [ -n "$add" ] && printf '%s\t%s\n' "$num" "$add" >>"$GH_STATE"
        ;;
      view)
        num="${3:-}"
        json_field=""
        args=("$@")
        for ((i = 0; i < ${#args[@]}; i++)); do
          [ "${args[i]}" = "--json" ] && json_field="${args[i + 1]:-}"
        done
        case "$json_field" in
          body)
            bodyvar="FAKE_GH_ISSUE_BODY_${num}"
            printf '%s\n' "${!bodyvar:-}"
            ;;
          labels)
            cur=""
            if [ -f "$GH_STATE" ]; then
              while IFS=$'\t' read -r k v; do
                [ "$k" = "$num" ] && cur="$v"
              done < "$GH_STATE"
            fi
            [ -n "$cur" ] && printf '%s\n' "$cur"
            labelsvar="FAKE_GH_ISSUE_LABELS_${num}"
            [ -n "${!labelsvar:-}" ] && printf '%s\n' "${!labelsvar:-}"
            ;;
        esac
        ;;
    esac
    ;;
  pr)
    case "${2:-}" in
      view)
        pr_ref="${3:-}"
        json_field=""
        args=("$@")
        for ((i = 0; i < ${#args[@]}; i++)); do
          [ "${args[i]}" = "--json" ] && json_field="${args[i + 1]:-}"
        done
        pr_num="${pr_ref##*/}"
        case "$json_field" in
          state)
            # Dynamic state written by `gh pr merge` takes precedence.
            dyn_state=""
            if [ -f "$GH_STATE" ]; then
              while IFS=$'\t' read -r k v; do
                [ "$k" = "pr-state-$pr_num" ] && dyn_state="$v"
              done <"$GH_STATE"
            fi
            if [ -n "$dyn_state" ]; then
              printf '%s\n' "$dyn_state"
            else
              statevar="FAKE_GH_PR_STATE_${pr_num}"
              printf '%s\n' "${!statevar:-}"
            fi
            ;;
        esac
        ;;
      checks)
        pr_ref="${3:-}"
        pr_num="${pr_ref##*/}"
        checksvar="FAKE_GH_PR_CHECKS_${pr_num}"
        case "${!checksvar:-none}" in
          success) printf 'CI\tpass\thttps://example.com\n' ;;
          failure) printf 'CI\tfail\thttps://example.com\n' ;;
          pending) printf 'CI\tpending\thttps://example.com\n' ;;
          none) ;; # no output — "not started"
        esac
        ;;
      merge)
        pr_ref="${3:-}"
        pr_num="${pr_ref##*/}"
        printf 'pr-state-%s\tMERGED\n' "$pr_num" >>"$GH_STATE"
        ;;
    esac
    ;;
esac

exit 0
