#!/usr/bin/env bash
# Fake podman for tests. Records every invocation's arguments to $PODMAN_LOG
# (one line per call) and simulates just enough behaviour for the harness
# scripts: `image exists`, `load`, and `run`. Never touches a real container.
set -euo pipefail

: "${PODMAN_LOG:?PODMAN_LOG must point at a log file}"
printf '%s\n' "$*" >>"$PODMAN_LOG"

case "${1:-}" in
  image)
    # `podman image inspect <ref>` — presence is controlled by the test.
    # Also accept the legacy `image exists` verb for any tests not yet updated.
    if [ "${2:-}" = "inspect" ] || [ "${2:-}" = "exists" ]; then
      [ "${FAKE_PODMAN_IMAGE_PRESENT:-0}" = "1" ]
      exit $?
    fi
    ;;
  run)
    # `podman run ...` — scripted exit code drives run.sh's failure path.
    issue_num=""
    complete_label=""
    for arg in "$@"; do
      case "$arg" in
        ISSUE_NUMBER=*) issue_num="${arg#ISSUE_NUMBER=}" ;;
        COMPLETE_LABEL=*) complete_label="${arg#COMPLETE_LABEL=}" ;;
      esac
    done
    # When FAKE_PODMAN_AUTO_COMPLETE=1 and the run succeeds, simulate the agent
    # reaching the complete label by writing it to GH_STATE.
    if [ "${FAKE_PODMAN_AUTO_COMPLETE:-0}" = "1" ] &&
       [ "${FAKE_PODMAN_RUN_EXIT:-0}" = "0" ] &&
       [ -n "${GH_STATE:-}" ] &&
       [ -n "$issue_num" ] && [ -n "$complete_label" ]; then
      printf '%s\t%s\n' "$issue_num" "$complete_label" >>"$GH_STATE"
    fi
    # Emit a scripted SPINDRIFT_OUTCOME line per issue (captured into the issue log).
    if [ -n "$issue_num" ]; then
      outcome_var="FAKE_PODMAN_OUTCOME_${issue_num}"
      [ -n "${!outcome_var:-}" ] && printf '%s\n' "${!outcome_var}"
    fi
    exit "${FAKE_PODMAN_RUN_EXIT:-0}"
    ;;
esac

exit 0
